{
  "manifest_version": 3,
  "name": "Tonecheck — Toxicity Diagnostic",
  "version": "1.0.0",
  "description": "Analyze text for toxicity with ML + RAG-powered explanations and constructive rewrites.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Tonecheck",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["activeTab", "scripting", "contextMenus", "storage"],
  "host_permissions": ["http://127.0.0.1:5000/*", "http://localhost:5000/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
